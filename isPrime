import java.lang.Math;


class Source {
  public static boolean isPrime(int number) {
    // a prime number is 2 and up, so 1 should return false
    if (number < 2) {
      return false;
    }

    // get the sqr root of the number
    double sqrNum = Math.sqrt(number);

    // for and int between 2 and the sqr root of number
    // check if the number is divisible
    // if it is, return false
    for (int i = 2; i <= sqrNum; i++) {
      if (number % i == 0) {
        return false;
      }
    }
    return true;
  }

